Algoritmo pract_While
	Escribir "ADIVINA EL NUMERO SECRETO"
	Escribir "ingrese un numero"
	Escribir "tienes 3 oportunidades"
	Leer N
	NumSecreto <- 45
	oportunidades <- 3
	intentos <- 0
	Mientras N <> NumSecreto y intentos < oportunidades Hacer
		intentos <- intentos + 1
		si N < 35 o N > 55 Entonces
			Escribir "FRIO"
		SiNo
			si N >= 35 y N < 40 o N > 50 y N <= 55 Entonces
				Escribir "TIBIO"
			SiNo
				Escribir "CALIENTE"
			FinSi
		FinSi
		Escribir "Le quedan ",oportunidades - intentos, " intentos sobrantes"
		Escribir "PRUEBA CON OTRO NUMERO"
		Leer N
	FinMientras
	si N = NumSecreto Entonces
		Escribir "FELICIDADES ACERTASTE EL NUMERO ERA: ",NumSecreto
	SiNo
		Escribir "TE QUEDASTE SIN INTENTO QUE MAL :c"
	FinSi
FinAlgoritmo